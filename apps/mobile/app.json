{
  "expo": {
    "name": "TouchGrass",
    "slug": "touchgrass",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/grass.png",
    "scheme": "com.adilhusain.touchgrass",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/grass.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.adilhusain.touchgrass",
      "associatedDomains": [
        "webcredentials:thirdweb.com",
        "applinks:thirdweb.com"
      ]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/grass.png",
        "backgroundColor": "#F4EEDF"
      },
      "package": "com.adilhusain.touchgrass",
      "permissions": [
        "android.permission.PACKAGE_USAGE_STATS"
      ],
      "intentFilters": [
        {
          "autoVerify": true,
          "action": "VIEW",
          "data": {
            "scheme": "https",
            "host": "thirdweb.com"
          },
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          },
          "ios": {
            "extraPods": [
              {
                "name": "OpenSSL-Universal",
                "configurations": [
                  "Release",
                  "Debug"
                ],
                "modular_headers": true,
                "version": "3.3.2000"
              }
            ]
          }
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {}
    }
  }
}
